{
  "id": "paternity-leave-request-by-pritesh-chavan",
  "title": "Paternity Leave Request",
  "createdBy": "Pritesh Chavan",
  "workspaceName": "Acme Inc",
  "personas": [
    {
      "id": "sarah",
      "name": "Sarah Chen",
      "designation": "Manager",
      "role": "Asks in #team-leave; approves Alex's paternity leave in Slackbot",
      "type": "user"
    },
    {
      "id": "alex",
      "name": "Alex Kim",
      "designation": "Employee",
      "role": "Replies in-channel; applies for paternity leave via Slackbot",
      "type": "user"
    },
    {
      "id": "slackbot",
      "name": "Slackbot",
      "designation": "App",
      "role": "Explains policy, collects dates, routes manager approval",
      "type": "app"
    }
  ],
  "steps": [
    {
      "id": "step-1",
      "type": "surface",
      "context": { "surface": "channel", "channel": "#team-leave" }
    },
    {
      "id": "step-2",
      "type": "user_message",
      "content": {
        "text": "Who's taking leave this month?",
        "personaId": "sarah"
      }
    },
    {
      "id": "step-3",
      "type": "user_message",
      "content": {
        "text": "I'd like to take leave.",
        "personaId": "alex"
      }
    },
    {
      "id": "step-4",
      "type": "surface",
      "viewport": { "mode": "dual", "left": "channel", "right": "slackbot" },
      "context": { "surface": "dm", "with": "Slackbot" }
    },
    {
      "id": "step-5",
      "type": "user_message",
      "viewport": { "mode": "dual", "left": "channel", "right": "slackbot" },
      "content": {
        "text": "I want to apply for paternity leave.",
        "personaId": "alex"
      }
    },
    {
      "id": "step-6",
      "type": "bot_typing",
      "viewport": { "mode": "dual", "left": "channel", "right": "slackbot" },
      "content": { "duration": 1, "statusText": "Checking leave policy…" }
    },
    {
      "id": "step-7",
      "type": "app_message",
      "viewport": { "mode": "dual", "left": "channel", "right": "slackbot" },
      "content": {
        "personaId": "slackbot",
        "templateId": "text_with_buttons",
        "text": "Hi Alex!\n\nI've noticed you're applying for paternity leave — congrats on the new chapter. Here's the snapshot from *your workspace* policy:\n\n*Paternity leave*\n• Up to 2 weeks paid (where eligible)\n• *Manager approval* required before dates lock\n• Submit at least 2 weeks ahead when you can\n\nChoose an action below to continue.",
        "choices": ["Choose dates"]
      }
    },
    {
      "id": "step-8",
      "type": "user_action",
      "viewport": { "mode": "dual", "left": "channel", "right": "slackbot" },
      "content": {
        "action": "choose_dates",
        "trigger": "button",
        "personaId": "alex",
        "choices": ["Choose dates"]
      }
    },
    {
      "id": "step-9",
      "type": "modal_open",
      "viewport": { "mode": "dual", "left": "channel", "right": "slackbot" },
      "content": { "view": "date-picker" }
    },
    {
      "id": "step-10",
      "type": "modal_submit",
      "viewport": { "mode": "dual", "left": "channel", "right": "slackbot" },
      "content": {
        "values": { "start": "2026-03-15", "end": "2026-03-22" }
      }
    },
    {
      "id": "step-11",
      "type": "bot_typing",
      "viewport": { "mode": "dual", "left": "channel", "right": "slackbot" },
      "content": { "duration": 1, "statusText": "Sending to Sarah for approval…" }
    },
    {
      "id": "step-12",
      "type": "app_message",
      "viewport": { "mode": "single", "view": "slackbot" },
      "content": {
        "personaId": "slackbot",
        "templateId": "text_with_buttons",
        "text": "Hi Sarah!\n\nI've noticed a new leave request that needs your sign-off.\n\n*Request*\n• *Alex Kim* — paternity leave\n• *Dates:* Mar 15–22\n\nWhen you're ready, approve below and I'll lock it in Workday and let Alex know.\n\nChoose an action below to continue.",
        "choices": ["Approve"]
      }
    },
    {
      "id": "step-13",
      "type": "user_action",
      "viewport": { "mode": "single", "view": "slackbot" },
      "content": {
        "action": "approve_leave",
        "trigger": "button",
        "personaId": "sarah",
        "choices": ["Approve"]
      }
    },
    {
      "id": "step-14",
      "type": "app_message",
      "viewport": { "mode": "single", "view": "slackbot" },
      "content": {
        "personaId": "slackbot",
        "templateId": "plain_text",
        "text": "Thanks, Sarah! I've handled the approval — Alex has been notified and your records are updated. You're all set."
      }
    },
    {
      "id": "step-15",
      "type": "surface",
      "viewport": { "mode": "dual", "left": "channel", "right": "slackbot" },
      "context": { "surface": "dm", "with": "Slackbot" }
    },
    {
      "id": "step-16",
      "type": "app_message",
      "viewport": { "mode": "dual", "left": "channel", "right": "slackbot" },
      "content": {
        "personaId": "slackbot",
        "templateId": "plain_text",
        "text": "Hi Alex!\n\nI've handled the approval — *your paternity leave is confirmed* for *Mar 15–22*. I've updated Workday and your calendar block.\n\nYou're all set — enjoy that time with your family!"
      }
    }
  ]
}
